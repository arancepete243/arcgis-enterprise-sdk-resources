{
  "name": "logger",
  "version": "12.0.0",
  "description": "A shared logger for CDF",
  "main": "src/index.js",
  "scripts": {
    "test": "tape src/**/*.spec.js | tap-min",
    "depcheck": "depcheck --ignores=\"coverage-badges-cli\"",
    "cov-badge": "coverage-badges-cli --source .coverage/all/coverage-summary.json --output ./coverage.svg > /dev/null"
  },
  "contributors": [
    {
      "name": "Rich Gwozdz",
      "email": "rgwozdz@esri.com"
    },
    {
      "name": "Daniel Fenton"
    }
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "coverage-badges-cli": "^2.2.0",
    "proxyquire": "^2.1.3",
    "sinon": "^21.0.0",
    "tap-min": "^3.0.0",
    "tape": "^5.9.0"
  },
  "files": [
    "src/**/*.js",
    "index.d.ts",
    "!**/*.spec.js"
  ]
