{
  "name": "featureserver",
  "version": "12.0.0",
  "description": "A partial implementation of the GeoServices specification in JavaScript",
  "main": "src/index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "mocha '**/*.spec.js' --reporter even-more-min --recursive -t 5000",
    "depcheck": "depcheck --ignores=\"coverage-badges-cli\"",
    "cov-badge": "coverage-badges-cli --source .coverage/all/coverage-summary.json --output ./coverage.svg > /dev/null"
  },
  "contributors": [
    {
      "name": "Daniel Fenton"
    },
    {
      "name": "Rich Gwozdz",
      "email": "rgwozdz@esri.com"
    }
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@esri/proj-codes": "^3.5.0",
    "@terraformer/arcgis": "^2.1.2",
    "@turf/bbox-polygon": "^7.2.0",
    "@turf/envelope": "^7.2.0",
    "chroma-js": "^3.1.2",
    "esri-extent": "^1.1.3",
    "geojson-validation": "^1.0.2",
    "iso-datestring-validator": "^2.2.2",
    "joi": "^18.0.1",
    "lodash": "^4.17.21",
    "postgres-date": "^2.1.0",
    "proj4": "^2.19.10",
    "protobufjs": "^7.5.4",
    "reproject": "^1.2.7",
    "wkt-parser": "^1.5.2"
  },
  "devDependencies": {
    "coverage-badges-cli": "^2.2.0",
    "even-more-min": "^1.0.1",
    "mocha": "^11.7.2",
    "proxyquire": "^2.1.3",
    "should": "^13.2.3",
    "should-sinon": "0.0.6",
    "sinon": "^21.0.0"
  },
  "files": [
    "src/**/*.js",
    "index.d.ts",
    "!**/*.spec.js"
  ]
}
