{
  "name": "output-geoservices",
  "version": "12.0.0",
  "description": "Wraps FeatureServer as an output plugin",
  "main": "src/index.js",
  "scripts": {
    "test": "jest --silent",
    "depcheck": "depcheck --ignores=\"coverage-badges-cli\"",
    "cov-badge": "coverage-badges-cli --source .coverage/all/coverage-summary.json --output ./coverage.svg > /dev/null"
  },
  "contributors": [
    {
      "name": "Rich Gwozdz",
      "email": "rgwozdz@esri.com"
    },
    {
      "name": "Daniel Fenton"
    }
  ],
  "license": "Apache-2.0",
  "files": [
    "src/**/*.js",
    "index.d.ts",
    "!**/*.spec.js"
  ],
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "jest": {
    "coverageProvider": "v8",
    "coverageDirectory": ".coverage",
    "coverageReporters": [
      "json",
      "json-summary"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.spec.[jt]s?(x)"
    ]
  },
  "devDependencies": {
    "coverage-badges-cli": "^2.2.0"
  }
}
